server:
  port: 8080

spring:
  datasource:
    url: jdbc:h2:file:./data/testdb
    driver-class-name: org.h2.Driver
    username: sa
    password:

  h2:
    console:
      enabled: true
      path: /h2-console

  jpa:
    hibernate:
      ddl-auto: create
      show-sql: true


  data:
    redis:
      host: localhost
      port: 6379


  session:
    store-type: redis
    timeout: 30m
