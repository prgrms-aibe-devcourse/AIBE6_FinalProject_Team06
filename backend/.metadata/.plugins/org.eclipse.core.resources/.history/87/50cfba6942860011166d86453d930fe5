		}

		for (int i = 0; i < companyInfo.size(); i++) {
			companyViewInfo.add(new CompanyViewDTO(companyInfo.get(i).getId(), companyInfo.get(i).getCompanyNumber(),
					companyInfo.get(i).getCompanyName(), companyInfo.get(i).getCompanyType(),
					companyInfo.get(i).getCreateAT()));

