@RestController
@AllArgsConstructor
public class PostController {
	private final PostService postService;
	private final MemberService memberService;
	
	@Transactional
	@PostMapping("/insert/company")
	ComInResDTO InsertCompany(@RequestBody ComInInDTO In, HttpSession session) {
		if(session.getAttribute("kakaoId")==null) {
			throw new RuntimeException("로그인이 되지 않았습니다.");
		}
		CompanyInfo companyInfo = null;
		try {
			companyInfo = new CompanyInfo(In.getName(), In.getCompanyNumber());
		} catch (Exception e) {
			throw new RuntimeException("회사정보 저장이 되지 않았습니다.");
		}
		try {
			companyInfo = postService.save(companyInfo);
		} catch (Exception e) {
			throw new RuntimeException("회사정보 저장이 되지 않았습니다.");
		}
		return new ComInResDTO("ok", companyInfo.getId(),  companyInfo.getCompanyName(),
				companyInfo.getCompanyNumber(), companyInfo.getCreateAT());
	}

	@Transactional
	@PostMapping("/insert/product")
	ProInResDTO InsertProduct(@RequestBody ProInInDTO In, HttpSession session) {
		if(session.getAttribute("kakaoId")==null) {
			throw new RuntimeException("로그인이 되지 않았습니다.");
		}
		ProductInfo productInfo = null;
		try {
			productInfo = new ProductInfo(In.getProductNumber(), In.getName(), In.getStock(),
					In.getPrice(), In.getImage());
		} catch (Exception e) {
			throw new RuntimeException("제품정보 저장이 되지 않았습니다.");
		}
		try {
			productInfo = postService.save(productInfo);
		} catch (Exception e) {
			throw new RuntimeException("제품정보 저장이 되지 않았습니다.");
		}
		return new ProInResDTO("ok", productInfo.getId(), productInfo.getProductNumber(), productInfo.getProductName(),
				 productInfo.getStock(), productInfo.getProductPrice(),
				productInfo.getImage(), productInfo.getCreateAT());
	}

	@Transactional
	@PutMapping("/motify/product")
	ProMoResDTO UpdateProduct(@RequestBody ProMoInDTO In, HttpSession session) {
		if(session.getAttribute("kakaoId")==null) {
			throw new RuntimeException("로그인이 되지 않았습니다.");
		}
		ProductInfo productInfo = postService.findByProductNumber(In.getProductNumber());
		if (productInfo == null) {
			throw new RuntimeException("제품정보가 없습니다.");
		}
		productInfo.setProductName(In.getName());
		productInfo.setImage(In.getImage());
		productInfo.setProductName(In.getName());
		productInfo.setProductPrice(In.getPrice());

		productInfo.setStock(In.getStock());
		productInfo.setCreateAT(LocalDateTime.now());

		return new ProMoResDTO("ok", productInfo.getId(), productInfo.getProductNumber(), productInfo.getProductName(),
				 productInfo.getStock(), productInfo.getProductPrice(),
				productInfo.getImage(), productInfo.getCreateAT());
	}

	@Transactional
	@PutMapping("/motify/company")
	ComMoResDTO MotifyCompany(@RequestBody ComMoInDTO In, HttpSession session) {
		if(session.getAttribute("kakaoId")==null) {
			throw new RuntimeException("로그인이 되지 않았습니다.");
		}
		CompanyInfo companyInfo = postService.findByCompanyNumber(In.getCompanyNumber());
		if (companyInfo == null) {
			throw new RuntimeException("회사정보가 없습니다.");
		}
		companyInfo.setCompanyName(In.getName());
		companyInfo.setCompanyNumber(In.getCompanyNumber());
	
		companyInfo.setCreateAT(LocalDateTime.now());

		return new ComMoResDTO("ok", companyInfo.getId(),  companyInfo.getCompanyName(),
				companyInfo.getCompanyNumber(), companyInfo.getCreateAT());
	}

	@Transactional
	@DeleteMapping("/delete/product")
	ProductInfoDTO DeleteProduct(@RequestBody DeleteProductDTO In, HttpSession session) {
		if(session.getAttribute("kakaoId")==null) {
			throw new RuntimeException("로그인이 되지 않았습니다.");
		}
		try {
			postService.delete(In.getId());
		} catch (Exception e) {
			throw new RuntimeException("제품정보 삭제가 되지 않았습니다.");
		}
		return new ProductInfoDTO("ok");
	}

	@Transactional
	@DeleteMapping("/delete/company")
	CompanyInfoDTO DeleteCompany(@RequestBody DeleteCompanyDTO In, HttpSession session) {
		if(session.getAttribute("kakaoId")==null) {
			throw new RuntimeException("로그인이 되지 않았습니다.");
		}
		try {
			postService.deleteCompany(In.getId());
		} catch (Exception e) {
			throw new RuntimeException("회사정보 삭제가 되지 않았습니다.");
		}
		return new CompanyInfoDTO("ok");
	}

	@Transactional
	@PostMapping("/view/product")
	List<ProductViewDto> ViewProduct(HttpSession session) {
	
		List<ProductInfo> productInfo = null;
		List<ProductViewDto> productViewInfo = new ArrayList<>();
		try {
			productInfo = postService.findAll();
		} catch (Exception e) {
			throw new RuntimeException("제품정보가 없습니다.");
		}
		
		for (int i = 0; i < productInfo.size(); i++) {
			productViewInfo.add(new ProductViewDto(productInfo.get(i).getId(), productInfo.get(i).getProductNumber(),
					productInfo.get(i).getProductName(),
					productInfo.get(i).getStock(), productInfo.get(i).getProductPrice(), productInfo.get(i).getImage(),
					productInfo.get(i).getCreateAT()));

		}

		return productViewInfo;
	}

	@Transactional
	@PostMapping("/view/company")
	List<CompanyViewDTO> ViewCompany(HttpSession session) {
	
		List<CompanyInfo> companyInfo = null;
		List<CompanyViewDTO> companyViewInfo = new ArrayList<>();
		try {
			companyInfo = postService.findAllCompany();
		} catch (Exception e) {
			throw new RuntimeException("회사정보가 없습니다.");
		}

		for (int i = 0; i < companyInfo.size(); i++) {
			companyViewInfo.add(new CompanyViewDTO(companyInfo.get(i).getId(), companyInfo.get(i).getCompanyNumber(),
					companyInfo.get(i).getCompanyName(),
					companyInfo.get(i).getCreateAT()));

		}

		return companyViewInfo;
	}
	
	@Transactional
	@PostMapping("/view/transaction")
	List<TotalDTO> ViewTransaction(HttpSession session) {
	
		List<SalesList> sales = null;
		List<BuyList> buys = null;
		List<TotalDTO> totalDTO = new ArrayList<>();
		try {
			sales = postService.findAllSales();
		} catch (Exception e) {
			throw new RuntimeException("sales정보가 없습니다.");
		}
		try {
			buys = postService.findAllBuys();
		} catch (Exception e) {
			throw new RuntimeException("buys정보가 없습니다.");
		}
		
		for(int i=0; i< sales.size();i++) {
			totalDTO.add(new TotalDTO(sales.get(i).getId(), sales.get(i).getSalesDate(), sales.get(i).getContentType(),sales.get(i).getTrade().getProduct().getCompany().getCompanyInfo().getCompanyName(),
					sales.get(i).getTrade().getProduct().getProductInfo().getProductName(), sales.get(i).getTrade().getProduct().getCompany().getUser().getAuth().getNickname(),
					sales.get(i).getSalesQualtity(),sales.get(i).getTrade().getProduct().getProductInfo().getProductPrice(), sales.get(i).getTrade().getProduct().getProductInfo().getImage()));
		}
		for(int i= 0; i< buys.size();i++) {
			totalDTO.add(new TotalDTO(buys.get(i).getId()+sales.size(), buys.get(i).getBuyDate(), buys.get(i).getContentType(),buys.get(i).getTrade().getProduct().getCompany().getCompanyInfo().getCompanyName(),
					buys.get(i).getTrade().getProduct().getProductInfo().getProductName(), buys.get(i).getTrade().getProduct().getCompany().getUser().getAuth().getNickname(),
					buys.get(i).getBuyQualtity(),buys.get(i).getTrade().getProduct().getProductInfo().getProductPrice(), buys.get(i).getTrade().getProduct().getProductInfo().getImage()));
		}
		return totalDTO;
	}
	
	@Transactional
	@PostMapping("/insert/ProductList")
	ListDto ProductList(@RequestBody InsertListDTO In, HttpSession session) {
		if(session.getAttribute("kakaoId")==null) {
			throw new RuntimeException("로그인이 필요합니다.");
		}
		
		Long KakaoId = (Long)session.getAttribute("kakaoId");
		
		CompanyInfo comInfo = postService.findByCompanyName(In.getCompany());
	
		Auth auth = memberService.findById(KakaoId);
		UserInfo userInfo = memberService.findByAuth(auth);
		ProductInfo productInFo = postService.findByProductName(In.getProduct());
		Company company = null;
		try {
			
			company=postService.findByCompanyInfo(comInfo);
			if(company==null) {
				company = new Company(userInfo, comInfo, In.getFlow());
				company = postService.save(company);
			}
		
		}catch(Exception e) {
			company=postService.findByCompanyInfo(comInfo);
		}
		Product product = null;
		try {
			product = new Product(productInFo, company);
		}catch(Exception e) {
			product = postService.findByCompanyName(company);
		}
		
		Trade trade = null;
		try {
			trade = new Trade(product);
		}catch(Exception e) {
			trade = postService.findByProduct(product);
		}
		
		try {
			product.getTrade().add(trade);
			product = postService.save(product);
		}catch(Exception e) {
			
		}
		SalesList saleslist = null;
		BuyList buylist = null;
		if(In.getFlow().equals("in")) {
			buylist = new BuyList(In.getFlow(), In.getQuantity(), trade);
			trade.getBuylist().add(buylist);
		}else {
			saleslist = new Sales	List(In.getFlow(), In.getQuantity(), trade);
			trade.getSaleslist().add(saleslist);
		}
		
		try {
			
			trade = postService.save(trade);
			if(In.getFlow().equals("in")) {
				buylist = postService.save(buylist);
			}else {
				saleslist = postService.save(saleslist);
			}
			
		}catch(Exception e) {
			
		}
		
		if(In.getFlow().equals("in")) {
			return new ListDto(buylist.getId(), buylist.getCreateAT(), buylist.getContentType(),
					company.getCompanyInfo().getCompanyName(),productInFo.getProductName(), auth.getNickname(), buylist.getBuyQualtity(),
					productInFo.getProductPrice(), productInFo.getImage());
		}else {
			return new ListDto(saleslist.getId(), saleslist.getCreateAT(), saleslist.getContentType(),
					company.getCompanyInfo().getCompanyName(),productInFo.getProductName(), auth.getNickname(), saleslist.getSalesQualtity(),
					productInFo.getProductPrice(), productInFo.getImage());
		}
		
	}
}
